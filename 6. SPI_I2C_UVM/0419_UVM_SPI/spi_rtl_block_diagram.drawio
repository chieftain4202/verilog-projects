<mxfile host="app.diagrams.net" modified="2026-04-19T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="spi-rtl-code-analysis" name="SPI RTL Code Analysis">
    <mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="0419_UVM_SPI RTL Block Diagram - Code Analysis" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="470" y="20" width="760" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="top_box" value="SPI_top&#xa;Top-level integration module&#xa;Inputs: clk, rst, ibtn, sbtn, sw[3:0]&#xa;Outputs: fnd_digit[3:0], fnd_data[7:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="80" width="1460" height="930" as="geometry"/>
        </mxCell>
        <mxCell id="external_inputs" value="External Inputs&#xa;clk&#xa;rst&#xa;sbtn: start button&#xa;ibtn: display/address button&#xa;sw[3:0]: data select" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="150" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="external_outputs" value="External Outputs&#xa;fnd_digit[3:0]&#xa;fnd_data[7:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1600" y="685" width="140" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="sw_data" value="sw_data module&#xa;always_comb&#xa;if sw &lt;= 9: hex_data={4'b0000, sw}&#xa;else: hex_data=8'h00&#xa;Output: sw_data[7:0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="145" width="250" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="deb_start" value="btn_debounce&#xa;u_btn_debounce_start&#xa;sbtn -&gt; osbtn&#xa;start pulse for SPI_master" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="315" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="deb_addr" value="btn_debounce&#xa;u_btn_debounce_addr&#xa;ibtn -&gt; obtn&#xa;display control input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="715" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="master" value="SPI_master u_master&#xa;FSM: IDLE -&gt; START -&gt; DATA -&gt; STOP&#xa;Mode in SPI_top: cpol=0, cpha=0, clk_div=8'd4&#xa;Inputs: tx_data=sw_data, start=osbtn, miso&#xa;Outputs: sclk, mosi, cs_n, t_idle, bit_cnt, rx_data, done, busy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="400" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="master_clk_div" value="Clock divider&#xa;div_cnt counts to clk_div&#xa;half_tick pulses when div_cnt == clk_div&#xa;half_tick toggles sclk_r in DATA state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="645" y="370" width="170" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="master_shift" value="Master datapath&#xa;tx_shift_reg loads tx_data on start&#xa;MOSI sends tx_shift_reg[7] MSB-first&#xa;rx_shift_reg shifts in MISO&#xa;rx_data captures final received byte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="835" y="370" width="210" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="master_status" value="Master status/control&#xa;bit_cnt counts 0..7&#xa;step selects receive/send half-cycle&#xa;busy=1 during transfer&#xa;done=1 in STOP&#xa;t_idle=1 in STOP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1065" y="370" width="200" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="spi_bus" value="Internal SPI bus in SPI_top&#xa;sclk: generated by master&#xa;mosi: master -&gt; slave&#xa;miso: slave -&gt; master&#xa;cs_n: active-low slave select&#xa;t_idle, bit_cnt: helper signals to slave" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1125" y="205" width="240" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="slave" value="SPI_slave u_slave&#xa;Inputs: sclk, rst, mosi, tx_data, bit_cnt, cs_n, t_idle&#xa;Outputs: rx_data=slave_rx_data, sdone, miso&#xa;No explicit FSM; behavior controlled by cs_n and sclk edge detect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="610" width="400" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="slave_edge" value="SCLK edge detector&#xa;edge_d delays sclk by clk&#xa;e_rise = ~edge_d &amp; sclk&#xa;e_fall = ~sclk &amp; edge_d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="645" y="805" width="185" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="slave_shift" value="Slave datapath&#xa;rx_shift_reg shifts in MOSI on e_rise&#xa;rx_data mirrors rx_shift_reg while cs_n=0&#xa;tx_shift_reg &lt;= rx_shift_reg while selected&#xa;MISO driven from rx_shift_reg[7] on e_fall" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="805" width="240" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="slave_status" value="Slave status&#xa;sdone=1 while cs_n=0 in current RTL&#xa;fnd_controller uses sdone as done input&#xa;Note: t_idle input exists but is not used inside SPI_slave" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#82b366;dashed=1;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1125" y="805" width="240" height="115" as="geometry"/>
        </mxCell>
        <mxCell id="fnd" value="fnd_controller u_fnd&#xa;sum=slave_rx_data&#xa;done=sdone&#xa;ibtn=obtn&#xa;outputs fnd_digit/fnd_data&#xa;Note: module source is not in 0419_UVM_SPI/rtl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1230" y="630" width="260" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="notes" value="Code-level observations&#xa;1. SPI_top declares some unused signals: slave_done, slave_busy, cpol, cpha, master_tx_data, master_start, s_tx_data.&#xa;2. slave_tx_data is connected to SPI_slave.tx_data but is not assigned in SPI_top.&#xa;3. SPI_slave currently loops rx_shift_reg toward MISO rather than using tx_data as an independent response payload.&#xa;4. fnd_controller is instantiated but its module definition is not present in the SPI rtl folder." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="955" width="1260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_sw_in" value="sw[3:0]" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="external_inputs" target="sw_data">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_start_btn" value="sbtn" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="external_inputs" target="deb_start">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_addr_btn" value="ibtn" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="external_inputs" target="deb_addr">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_sw_master" value="sw_data[7:0] to tx_data" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="sw_data" target="master">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_start_master" value="osbtn to start" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="deb_start" target="master">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_master_div" value="clk_div and half_tick logic" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="master" target="master_clk_div">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_master_shift" value="shift registers" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="master" target="master_shift">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_master_status" value="state, bit_cnt, step" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="master" target="master_status">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_master_bus" value="sclk, mosi, cs_n, t_idle, bit_cnt" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="master" target="spi_bus">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_bus_slave" value="sclk, mosi, cs_n, t_idle, bit_cnt" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="spi_bus" target="slave">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_slave_miso_bus" value="miso" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="slave" target="spi_bus">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_bus_master_miso" value="miso" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="spi_bus" target="master">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_slave_edge" value="sclk edge detect" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="slave" target="slave_edge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_slave_shift" value="rx/tx shift registers" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="slave" target="slave_shift">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_slave_status" value="sdone and current RTL notes" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="slave" target="slave_status">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_slave_fnd" value="slave_rx_data, sdone" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="slave" target="fnd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_deb_addr_fnd" value="obtn" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="deb_addr" target="fnd">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_fnd_out" value="fnd_digit/fnd_data" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="fnd" target="external_outputs">
          <mxGeometry relative="1" as="geometry"/>
